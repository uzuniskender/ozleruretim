// 3. ALAN ADI DÖNÜŞÜMÜ — camelCase (JS) ↔ snake_case (DB)
function toSnake(obj) {
  if (!obj || typeof obj !== 'object') return obj;
  if (Array.isArray(obj)) return obj.map(toSnake);
  const out = {};
  for (const [k, v] of Object.entries(obj)) {
    const sk = k.replace(/[A-Z]/g, m => '_' + m.toLowerCase());
    // Özel alan dönüşümleri
    const mapped = {
      'orderId': 'order_id', 'woId': 'wo_id', 'opId': 'op_id',
      'istId': 'ist_id', 'mamulKod': 'mamul_kod', 'mamulAd': 'mamul_ad',
      'siparisNo': 'siparis_no', 'receteId': 'recete_id',
      'hamMalkod': 'ham_malkod', 'hamMalad': 'ham_malad',
      'whAlloc': 'wh_alloc', 'ieNo': 'ie_no', 'bomId': 'bom_id',
      'hazirlikSure': 'hazirlik_sure', 'islemSure': 'islem_sure',
      'firePct': 'fire_pct', 'parcaBoy': 'parca_boy', 'parcaEn': 'parca_en',
      'hamBoy': 'ham_boy', 'hamEn': 'ham_en', 'kesimTip': 'kesim_tip',
      'not': 'not_', 'opIds': 'op_ids', 'beklenenTarih': 'beklenen_tarih',
      'gerceklesenTarih': 'gerceklesen_tarih', 'tedarikciId': 'tedarikci_id',
      'durusDk': 'durus_dk', 'durusKod': 'durus_kod', 'sortOrder': 'sort_order'
    }[k] || sk;
    out[mapped] = (typeof v === 'object' && v !== null && !Array.isArray(v)) ? toSnake(v) : v;
  }
  return out;
}

function toCamel(obj) {
  if (!obj || typeof obj !== 'object') return obj;
  if (Array.isArray(obj)) return obj.map(toCamel);
  const out = {};
  for (const [k, v] of Object.entries(obj)) {
    const ck = k.replace(/_([a-z])/g, (_, c) => c.toUpperCase());
    const mapped = (k === 'not_') ? 'not' : ck;
    out[mapped] = (typeof v === 'object' && v !== null && !Array.isArray(v)) ? toCamel(v) : v;
  }
  return out;
}

// 4. CRUD FONKSİYONLARI
const db = {
  // Tablodaki tüm kayıtları çek
  async getAll(sKey) {
    const table = TABLE_MAP[sKey];
    if (!table) { console.warn('Bilinmeyen tablo:', sKey); return []; }
    const { data, error } = await supabase.from(table).select('*');
    if (error) { console.error('getAll hata:', table, error); return []; }
    return (data || []).map(toCamel);
  },

  // Tek kayıt ekle
  async insert(sKey, record) {
    const table = TABLE_MAP[sKey];
    if (!table) return null;
    const row = toSnake(record);
    const { data, error } = await supabase.from(table).insert(row).select().single();
    if (error) { console.error('insert hata:', table, error); return null; }
    return toCamel(data);
  },

  // Tek kayıt güncelle
  async update(sKey, id, changes) {
    const table = TABLE_MAP[sKey];
    if (!table) return null;
    const row = toSnake(changes);
    const { data, error } = await supabase.from(table).update(row).eq('id', id).select().single();
    if (error) { console.error('update hata:', table, error); return null; }
    return toCamel(data);
  },

  // Tek kayıt sil
  async remove(sKey, id) {
    const table = TABLE_MAP[sKey];
    if (!table) return false;
    const { error } = await supabase.from(table).delete().eq('id', id);
    if (error) { console.error('delete hata:', table, error); return false; }
    return true;
  },

  // Çoklu kayıt sil
  async removeMany(sKey, ids) {
    const table = TABLE_MAP[sKey];
    if (!table) return false;
    const { error } = await supabase.from(table).delete().in('id', ids);
    if (error) { console.error('deleteMany hata:', table, error); return false; }
    return true;
  },

  // Upsert (varsa güncelle, yoksa ekle)
  async upsert(sKey, record) {
    const table = TABLE_MAP[sKey];
    if (!table) return null;
    const row = toSnake(record);
    const { data, error } = await supabase.from(table).upsert(row).select().single();
    if (error) { console.error('upsert hata:', table, error); return null; }
    return toCamel(data);
  },

  // Toplu insert
  async insertMany(sKey, records) {
    const table = TABLE_MAP[sKey];
    if (!table) return [];
    const rows = records.map(toSnake);
    const { data, error } = await supabase.from(table).insert(rows).select();
    if (error) { console.error('insertMany hata:', table, error); return []; }
    return (data || []).map(toCamel);
  }
};

// 5. S OBJESİNİ SUPABASE'DEN YÜKLE (başlangıç)
async function loadAllFromSupabase() {
  const keys = Object.keys(TABLE_MAP);
  const promises = keys.map(k => db.getAll(k));
  const results = await Promise.all(promises);
  keys.forEach((k, i) => { S[k] = results[i]; });
  console.log('✅ Tüm veriler Supabase\'den yüklendi.');
}

