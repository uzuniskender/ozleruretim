// 7. MİGRASYON YARDIMCISI — localStorage → Supabase (tek seferlik)
async function migrateLocalStorageToSupabase() {
  const raw = localStorage.getItem('uys_data');
  if (!raw) { console.log('localStorage boş, migrasyon gerekli değil.'); return; }
  
  const data = JSON.parse(raw);
  let count = 0;
  
  for (const [sKey, table] of Object.entries(TABLE_MAP)) {
    const arr = data[sKey];
    if (!arr || !Array.isArray(arr) || arr.length === 0) continue;
    
    console.log(`Migrating ${sKey}: ${arr.length} kayıt...`);
    const rows = arr.map(toSnake);
    
    // Batch insert (Supabase max 1000/request)
    for (let i = 0; i < rows.length; i += 500) {
      const batch = rows.slice(i, i + 500);
      const { error } = await supabase.from(table).upsert(batch, { onConflict: 'id' });
      if (error) console.error(`  ❌ ${sKey} batch hata:`, error.message);
      else count += batch.length;
    }
  }

  // Ayarlar (S.ayarlar varsa)
  if (data.ayarlar && typeof data.ayarlar === 'object') {
    for (const [k, v] of Object.entries(data.ayarlar)) {
      await supabase.from('ayarlar').upsert({ key: k, value: String(v) });
    }
  }

  console.log(`✅ Migrasyon tamamlandı: ${count} kayıt aktarıldı.`);
  
  // Flag koy — tekrar çalışmasın
  localStorage.setItem('_uys_migrated_supabase', '1');
}

// 8. BAŞLATMA
async function initUYS() {
  // İlk açılışta migrasyon kontrol
  if (localStorage.getItem('_uys_migrated_supabase') !== '1') {
    const raw = localStorage.getItem('uys_data');
    if (raw) {
      console.log('🔄 localStorage → Supabase migrasyon başlıyor...');
      await migrateLocalStorageToSupabase();
    }
  }
  
  // Supabase'den yükle
  await loadAllFromSupabase();
  
  // UI'ı başlat
  if (typeof nav === 'function') nav('orders');
}

