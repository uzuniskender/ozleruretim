// 2. TABLO HARİTASI — S objesi key → Supabase tablo adı
const TABLE_MAP = {
  operations:      'operations',
  stations:        'stations',
  malzemeler:      'malzemeler',
  bomTrees:        'bom_trees',
  recipes:         'recipes',
